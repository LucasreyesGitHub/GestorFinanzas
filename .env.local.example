# ─── NextAuth ───────────────────────────────────────────
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET=TU_SECRET_AQUI
# En desarrollo: http://localhost:3000
# En Vercel: https://TU-APP.vercel.app
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────
# 1. Ir a https://console.cloud.google.com
# 2. Crear proyecto → APIs & Services → OAuth consent screen (External)
# 3. Credentials → Create Credentials → OAuth client ID → Web application
# 4. Authorized redirect URIs:
#      http://localhost:3000/api/auth/callback/google   (desarrollo)
#      https://TU-APP.vercel.app/api/auth/callback/google  (producción)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-client-secret

# ─── Base de datos (Turso) ───────────────────────────────
# 1. npm install -g @turso/cli
# 2. turso auth login
# 3. turso db create finanzas-personal
# 4. turso db show finanzas-personal   → copiar URL
# 5. turso db tokens create finanzas-personal  → copiar token
# 6. turso db shell finanzas-personal < lib/schema.sql
TURSO_DATABASE_URL=libsql://tu-db.turso.io
TURSO_AUTH_TOKEN=eyTU_TOKEN_AQUI
